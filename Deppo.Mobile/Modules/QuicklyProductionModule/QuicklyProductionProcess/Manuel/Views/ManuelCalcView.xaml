<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Deppo.Mobile.Modules.QuicklyProductionModule.QuicklyProductionProcess.Manuel.Views.ManuelCalcView"
             xmlns:fontAwesome="clr-namespace:Deppo.Mobile.Helpers.FontAwesomeHelper"
             xmlns:model="clr-namespace:Deppo.Core.Models;assembly=Deppo.Core"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:bomBasketModel="clr-namespace:Deppo.Mobile.Core.Models.QuicklyModels.BasketModels;assembly=Deppo.Mobile.Core"
             xmlns:bomProductModel="clr-namespace:Deppo.Mobile.Core.Models.QuicklyModels;assembly=Deppo.Mobile.Core"
             xmlns:viewModel="clr-namespace:Deppo.Mobile.Modules.QuicklyProductionModule.QuicklyProductionProcess.Manuel.ViewModels"
             Title="{Binding Title}"
             x:DataType="viewModel:ManuelCalcViewModel"
             Shell.TabBarIsVisible="False">
    <ContentPage.Behaviors>

        <toolkit:StatusBarBehavior StatusBarColor="{StaticResource Primary}"
                                   StatusBarStyle="Default" />
    </ContentPage.Behaviors>

    <ContentPage.Resources>
        <ResourceDictionary>
            <toolkit:ByteArrayToImageSourceConverter x:Key="ByteArrayToImageSourceConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.BackgroundImageSource>
        <OnPlatform x:TypeArguments="ImageSource">
            <On Platform="Android"
                Value="artboard.png" />
        </OnPlatform>
    </ContentPage.BackgroundImageSource>

    <Grid Padding="10"
          RowDefinitions=".40*, .60*"
          RowSpacing="10">

        <VerticalStackLayout Grid.Row="0"
                             Padding="10"
                             HorizontalOptions="Fill"
                             Spacing="10"
                             VerticalOptions="Center">
            <!--#region Image-->
            <Border BackgroundColor="{StaticResource Secondary}"
                    HeightRequest="100"
                    StrokeShape="RoundRectangle 50"
                    StrokeThickness="0"
                    VerticalOptions="Center"
                    WidthRequest="100">
                <!--<Image Source="{Binding ProductDetailModel.Product.Image, Converter={StaticResource ByteArrayToImageSourceConverter}}" />-->
            </Border>
            <!--#endregion-->

            <!--#region Code, Name, StockQuantity-->
            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="4">
                <Label FontAttributes="Bold"
                       FontSize="Large"
                       HorizontalOptions="Center"
                       LineBreakMode="TailTruncation"
                       MaxLines="1"
                       Text="{Binding QuicklyBomProductBasketModel.QuicklyBomProduct.Code }" />
                <Label FontSize="Medium"
                       HorizontalOptions="Center"
                       LineBreakMode="TailTruncation"
                       MaxLines="1"
                       Text="{Binding QuicklyBomProductBasketModel.QuicklyBomProduct.Name}"
                       TextColor="{StaticResource Gray600}" />
            </VerticalStackLayout>
            <!--#endregion-->

            <Grid ColumnDefinitions="Auto,Auto,Auto"
                  ColumnSpacing="10"
                  HorizontalOptions="Center">
                <Border Grid.Column="0"
                        Padding="5"
                        BackgroundColor="Transparent"
                        Stroke="{StaticResource Secondary}"
                        StrokeShape="RoundRectangle 2">
                    <Label FontFamily="FAS"
                           FontSize="Medium"
                           Text="{x:Static fontAwesome:FontAwesomeIcons.Minus}"
                           TextColor="{StaticResource Secondary}" />

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewModel:ManuelCalcViewModel}}, Path=DecreaseCommand}" />
                    </Border.GestureRecognizers>
                </Border>
                <Label Grid.Column="1"
                       FontAttributes="Bold"
                       FontSize="Large"
                       Text="{Binding QuicklyBomProductBasketModel.BOMQuantity}"
                       TextColor="{StaticResource OffBlack}"
                       VerticalOptions="Center" />
                <Border Grid.Column="2"
                        Padding="5"
                        BackgroundColor="{StaticResource Secondary}"
                        Stroke="{StaticResource Secondary}"
                        StrokeShape="RoundRectangle 2">
                    <Label FontFamily="FAS"
                           FontSize="Medium"
                           Text="{x:Static fontAwesome:FontAwesomeIcons.Plus}"
                           TextColor="{StaticResource White}" />

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewModel:ManuelCalcViewModel}}, Path=IncreaseCommand}"
                                              CommandParameter="{Binding .}" />
                    </Border.GestureRecognizers>
                </Border>
            </Grid>
        </VerticalStackLayout>

        <Grid Grid.Row="1"
              RowDefinitions="Auto, *"
              RowSpacing="10">
            <Grid ColumnDefinitions="Auto,.10*">
                <Label Grid.Column="0" FontAttributes="Bold" 
                       FontSize="Title"
                       Text="Sarf Malzemeleri"
                       TextColor="{StaticResource OffBlack}" />
                <Border Grid.Column="1"  Padding="5" 
                        HorizontalOptions="End"
                        BackgroundColor="{StaticResource White}"
                        Stroke="{StaticResource Secondary}"
                        StrokeShape="RoundRectangle">
                    <Label FontFamily="FAS"
                           FontSize="Medium"
                           Text="{x:Static fontAwesome:FontAwesomeIcons.Plus}"
                           TextColor="{StaticResource Secondary}" />

                    <!--<Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewModel:ManuelCalcViewModel}}, Path=IncreaseCommand}"
                                              CommandParameter="{Binding .}" />
                    </Border.GestureRecognizers>-->
                </Border>

            </Grid>
            <HorizontalStackLayout >
                
               

            </HorizontalStackLayout>

