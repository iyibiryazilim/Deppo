<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Deppo.Mobile.Modules.PurchaseModule.PurchaseProcess.InputProductPurchaseOrderProcess.Views.InputProductPurchaseOrderProcessProductListView"
             xmlns:dx="http://schemas.devexpress.com/maui"
             xmlns:fontAwesome="clr-namespace:Deppo.Mobile.Helpers.FontAwesomeHelper"
             xmlns:model="clr-namespace:Deppo.Core.Models;assembly=Deppo.Core"
             xmlns:purchaseModels="clr-namespace:Deppo.Mobile.Core.Models.PurchaseModels;assembly=Deppo.Mobile.Core"
             xmlns:selectConverter="clr-namespace:Deppo.Mobile.Modules.ProductModule.ProductProcess.InputProductProcess.Converters"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:viewModels="clr-namespace:Deppo.Mobile.Modules.PurchaseModule.PurchaseProcess.InputProductPurchaseOrderProcess.ViewModels"
             Title="{Binding Title}"
             x:DataType="viewModels:InputProductPurchaseOrderProcessProductListViewModel"
             Shell.TabBarIsVisible="False">
    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior Command="{Binding SwitchToOrderListViewCommand}"
                                        EventName="Loaded" />
        <toolkit:StatusBarBehavior StatusBarColor="{StaticResource Primary}"
                                   StatusBarStyle="Default" />
    </ContentPage.Behaviors>

    <ContentPage.Resources>
        <ResourceDictionary>
            <toolkit:ByteArrayToImageSourceConverter x:Key="ByteArrayToImageSourceConverter" />
            <selectConverter:SelectProductConverter x:Key="selectProductConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.BackgroundImageSource>
        <OnPlatform x:TypeArguments="ImageSource">
            <On Platform="Android"
                Value="artboard.png" />
        </OnPlatform>
    </ContentPage.BackgroundImageSource>

    <Grid RowDefinitions="Auto, *, Auto"
          RowSpacing="10">
        <Grid Grid.Row="0"
              Padding="10,0,10,0"
              ColumnDefinitions="*, *"
              ColumnSpacing="10">
            <Border Grid.Column="0"
                    Padding="10"
                    BackgroundColor="Transparent"
                    Stroke="{StaticResource White}"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="1">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SwitchToOrderListViewCommand}" />
                </Border.GestureRecognizers>
                <Border.Triggers>
                    <DataTrigger Binding="{Binding IsProductListVisible}"
                                 TargetType="Border"
                                 Value="True">
                        <Setter Property="BackgroundColor"
                                Value="{StaticResource Gray200}" />
                        <Setter Property="Stroke"
                                Value="Transparent" />
                    </DataTrigger>
                </Border.Triggers>
                <Label HorizontalOptions="Center"
                       Text="Siparişler"
                       TextColor="White"
                       VerticalOptions="Center">
                    <Label.Triggers>
                        <DataTrigger Binding="{Binding IsProductListVisible}"
                                     TargetType="Label"
                                     Value="True">
                            <Setter Property="TextColor"
                                    Value="{StaticResource Black}" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </Border>
            <Border Grid.Column="1"
                    Padding="10"
                    BackgroundColor="{StaticResource Gray200}"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="1">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SwitchToProductListViewCommand}" />
                </Border.GestureRecognizers>
                <Label HorizontalOptions="Center"
                       Text="Ürünler"
                       VerticalOptions="Center">
                    <Label.Triggers>
                        <DataTrigger Binding="{Binding IsProductListVisible}"
                                     TargetType="Label"
                                     Value="True">
                            <Setter Property="TextColor"
                                    Value="{StaticResource White}" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
                <Border.Triggers>
                    <DataTrigger Binding="{Binding IsProductListVisible}"
                                 TargetType="Border"
                                 Value="True">
                        <Setter Property="BackgroundColor"
                                Value="Transparent" />
                        <Setter Property="Stroke"
                                Value="{StaticResource White}" />
                    </DataTrigger>
                </Border.Triggers>
            </Border>
        </Grid>

        <!--#region Products List-->
        <CollectionView Grid.Row="1"
                        IsVisible="False"
                        ItemsSource="{Binding Products}">
            <CollectionView.Triggers>
                <DataTrigger Binding="{Binding IsProductListVisible}"
                             TargetType="CollectionView"
                             Value="true">
                    <Setter Property="IsVisible"
                            Value="true" />
                </DataTrigger>
            </CollectionView.Triggers>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="purchaseModels:PurchaseSupplierProduct">
                    <Border Padding="10"
                            BackgroundColor="Transparent"
                            StrokeShape="RoundRectangle 10"
                            StrokeThickness="0.1">

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="10">
                            <Border BackgroundColor="{StaticResource Secondary}"
                                    StrokeShape="RoundRectangle 5"
                                    StrokeThickness="0.5">
                                <Image Grid.Column="0"
                                       HeightRequest="50"
                                       Source="dotnet_bot.png"
                                       WidthRequest="50" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="2">
                                <Label FontAttributes="Bold"
                                       LineBreakMode="TailTruncation"
                                       Text="{Binding ItemCode}" />
                                <Label LineBreakMode="TailTruncation"
                                       Text="{Binding ItemName}"
                                       TextColor="{StaticResource Gray600}" />

                                <!--<Label TextColor="{StaticResource Gray600}" VerticalOptions="Center">
                                 <Label.FormattedText>
                                     <FormattedString>
                                         <Span FontAttributes="Bold"
                                               FontFamily="FAS"
                                               Text="{x:Static fontAwesome:FontAwesomeIcons.Box}"
                                               TextColor="{StaticResource Primary}" />
                                         <Span Text=" " />
                                         <Span FontAttributes="Bold"
                                               Text="{Binding StockQuantity, StringFormat='{0:N2}'}"
                                               TextColor="{StaticResource Primary}" />
                                         <Span Text=" " />
                                         <Span FontAttributes="Bold"
                                               Text="{Binding }"
                                               TextColor="{StaticResource Primary}" />
                                     </FormattedString>
                                 </Label.FormattedText>
                             </Label>-->
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <!--#endregion-->

        <!--#region Orders List-->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Orders}">
            <CollectionView.Triggers>
                <DataTrigger Binding="{Binding IsProductListVisible}"
                             TargetType="CollectionView"
                             Value="true">
                    <Setter Property="IsVisible"
                            Value="false" />
                </DataTrigger>
            </CollectionView.Triggers>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="model:WaitingSalesOrder">
                    <Border Padding="10"
                            BackgroundColor="Transparent"
                            StrokeShape="RoundRectangle 10"
                            StrokeThickness="0.1">

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="10">
                            <Border BackgroundColor="{StaticResource Secondary}"
                                    StrokeShape="RoundRectangle 5"
                                    StrokeThickness="0.5">
                                <Image Grid.Column="0"
                                       HeightRequest="50"
                                       Source="dotnet_bot.png"
                                       WidthRequest="50" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="2">
                                <Label FontAttributes="Bold"
                                       LineBreakMode="TailTruncation"
                                       Text="{Binding ProductCode}" />
                                <Label LineBreakMode="TailTruncation"
                                       Text="{Binding ProductName}"
                                       TextColor="{StaticResource Gray600}" />

                                <Label LineBreakMode="TailTruncation"
                                       Text="{Binding CustomerName}"
                                       TextColor="{StaticResource Gray600}" />

                                <!--<Label TextColor="{StaticResource Gray600}" VerticalOptions="Center">
                     <Label.FormattedText>
                         <FormattedString>
                             <Span FontAttributes="Bold"
                                   FontFamily="FAS"
                                   Text="{x:Static fontAwesome:FontAwesomeIcons.Box}"
                                   TextColor="{StaticResource Primary}" />
                             <Span Text=" " />
                             <Span FontAttributes="Bold"
                                   Text="{Binding StockQuantity, StringFormat='{0:N2}'}"
                                   TextColor="{StaticResource Primary}" />
                             <Span Text=" " />
                             <Span FontAttributes="Bold"
                                   Text="{Binding }"
                                   TextColor="{StaticResource Primary}" />
                         </FormattedString>
                     </Label.FormattedText>
                 </Label>-->
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <!--#endregion-->

        <Button Grid.Row="2"
                Margin="10,10,10,20"
                Command="{Binding NextViewCommand}"
                Text="İleri" />
    </Grid>
</ContentPage>