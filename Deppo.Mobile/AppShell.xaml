                                            Dark={StaticResource White}}" />
            </Tab.Icon>
            <ShellContent ContentTemplate="{DataTemplate oursourcePanelView:OutsourcePanelView}" />
        </Tab>

        <Tab Title="Fason Cariler">
            <Tab.Icon>
                <FontImageSource
                    FontFamily="FAS"
                    Glyph="{x:Static fontAwesome:FontAwesomeIcons.User}"
                    Size="20"
                    Color="{AppThemeBinding Light={StaticResource Primary},
                                            Dark={StaticResource White}}" />
            </Tab.Icon>
            <ShellContent ContentTemplate="{DataTemplate outsourceView:OutsourceListView}" />
        </Tab>


        <Tab Title="Bekleyen Ürünler">
            <Tab.Icon>
                <FontImageSource
                    FontFamily="FAS"
                    Glyph="{x:Static fontAwesome:FontAwesomeIcons.Cubes}"
                    Size="20"
                    Color="{AppThemeBinding Light={StaticResource Primary},
                                            Dark={StaticResource White}}" />
            </Tab.Icon>
            <ShellContent ContentTemplate="{DataTemplate waitingOutsourceProductView:WaitingOutsourceProductListView}" />
        </Tab>

        <Tab Title="İşlemler">
            <Tab.Icon>
                <FontImageSource
                    FontFamily="FAS"
                    Glyph="{x:Static fontAwesome:FontAwesomeIcons.GripVertical}"
                    Size="20"
                    Color="{AppThemeBinding Light={StaticResource Primary},
                                            Dark={StaticResource White}}" />
            </Tab.Icon>
            <ShellContent ContentTemplate="{DataTemplate outsourceProcessView:OutsourceProcessView}" />
        </Tab>
        <FlyoutItem.Icon>
            <FontImageSource
                FontFamily="FAS"
                Glyph="{x:Static fontAwesome:FontAwesomeIcons.ArrowRightArrowLeft}"
                Size="20"
                Color="{AppThemeBinding Light={StaticResource Primary},
                                        Dark={StaticResource White}}" />
        </FlyoutItem.Icon>

    </FlyoutItem>

    <FlyoutItem Title="Sayım İşlemi">
        <ShellContent ContentTemplate="{DataTemplate countingView:CountingWarehouseListView}" />
        <FlyoutItem.Icon>
            <FontImageSource
                FontFamily="FAS"
                Glyph="{x:Static fontAwesome:FontAwesomeIcons.FileContract}"
                Size="20"
                Color="{AppThemeBinding Light={StaticResource Primary},
                                        Dark={StaticResource White}}" />
        </FlyoutItem.Icon>
    </FlyoutItem>

    <FlyoutItem Title="Hızlı Üretim">
        <ShellContent ContentTemplate="{DataTemplate fastProductionView:FastProductionProductView}" />
        <FlyoutItem.Icon>
            <FontImageSource
                FontFamily="FAS"
                Glyph="{x:Static fontAwesome:FontAwesomeIcons.UserTie}"
                Size="20"
                Color="{AppThemeBinding Light={StaticResource Primary},
                                        Dark={StaticResource White}}" />
